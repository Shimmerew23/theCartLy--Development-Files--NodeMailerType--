# ============================
# SERVER CONFIG
# ============================
NODE_ENV=development                # In production (Render): NODE_ENV=production
PORT=5000                           # In production (Render): Render assigns PORT automatically, leave this unset or set to 10000
FRONTEND_URL=http://localhost:5173  # In production (Render): FRONTEND_URL=https://mcartly.vercel.app

# ============================
# DATABASE
# ============================
MONGODB_URI=mongodb://localhost:27017/curator_ecommerce # In production/local #MONGODB_URI=mongodb+srv://<username>:<password>@<cluster_name>.zx00ajd.mongodb.net/<db_name>?retryWrites=true&w=majority

# ============================
# REDIS
# ============================
REDIS_URL=redis://localhost:6379    # In production (Render): Use Upstash Redis free tier → REDIS_URL=rediss://:password@host:port

# ============================
# JWT SECRETS
# ============================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars          # In production/local, just generate random 32chr or 'openssl rand -base64 32' in bash/shell
JWT_ACCESS_EXPIRE=15m                                                           #
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production               # In production/local, just generate random 32chr or 'openssl rand -base64 32' in bash/shell 
JWT_REFRESH_EXPIRE=7d                                                           #
JWT_COOKIE_EXPIRE=7                                                             #

# ============================
# OAUTH - GOOGLE
# ============================
GOOGLE_CLIENT_ID=your_google_client_id                                                   # In production/local
GOOGLE_CLIENT_SECRET=your_google_client_secret                                           # In production/local
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback                       # In production (Render): GOOGLE_CALLBACK_URL=https://mcartly.onrender.com/api/auth/google/callback

# ============================
# OAUTH - FACEBOOK
# ============================
FACEBOOK_APP_ID=your_facebook_app_id                                                     #
FACEBOOK_APP_SECRET=your_facebook_app_secret                                             #
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback                   # # In production (Render): FACEBOOK_CALLBACK_URL=https://mcartly.onrender.com/api/auth/facebook/callback

# ============================
# SESSION
# ============================
SESSION_SECRET=your_session_secret_change_in_production                          # In production/local, just generate random 32chr or 'openssl rand -base64 32' in bash/shell 

# ============================
# EMAIL (Nodemailer)
# ============================
SMTP_HOST=smtp.gmail.com                # In production/local
SMTP_PORT=587                           # In production/local
SMTP_USER=your_email@gmail.com          # In production/local
SMTP_PASS=your_app_password             # In production/local
FROM_NAME=CartLy                        # In production/local
FROM_EMAIL=noreply@CartLy.com           # In production/local

# ============================
# STRIPE PAYMENTS
# ============================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================
# CLOUDINARY (Optional for cloud image storage)
# ============================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================
# RATE LIMITING
# ============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ============================
# CRYPTO
# ============================
CRYPTO_SECRET=your_crypto_secret_32_chars_minimum       # In production/local, just generate random 32chr or 'openssl rand -base64 32' in bash/shell 
